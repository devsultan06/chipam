<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #EEFFEB;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        .wrapper {
            width: 100%;
            table-layout: fixed;
            background-color: #EEFFEB;
            padding-bottom: 40px;
            padding-top: 40px;
        }

        .main {
            background-color: #ffffff;
            margin: 0 auto;
            width: 100%;
            max-width: 600px;
            border-spacing: 0;
            border-radius: 40px;
            overflow: hidden;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.02);
        }

        .banner {
            background-color: #58B947;
            background: linear-gradient(135deg, #58B947 0%, #4FA33F 100%);
            padding: 60px 40px;
            text-align: center;
            position: relative;
        }

        /* Logo Layout */
        .logo-container {
            margin-bottom: 24px;
            display: block;
            text-align: center;
        }

        .banner-title {
            color: #ffffff;
            font-size: 35px;
            font-weight: 500;
            margin: 0;
            letter-spacing: 0px;
            line-height: 1.1;
        }

        /* Main Body Content */
        .content {
            padding: 60px 50px;
            text-align: left;
        }

        .greeting {
            font-size: 18px;
            font-weight: 400;
            margin-bottom: 24px;
            color: #333333;
        }

        .intro-text {
            font-size: 18px;
            font-weight: 400;
            color: #333333;
            margin-bottom: 12px;
        }

        .message {
            font-size: 18px;
            line-height: 1.6;
            font-weight: 400;
            color: #333333;
            margin-bottom: 40px;
        }

        /* Call to Action Button */
        .button-container {
            text-align: center;
            margin-bottom: 60px;
        }

        .button {
            display: inline-block;
            background-color: #58B947;
            border: none;
            color: #ffffff !important;
            padding: 15px 40px;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 500;
            font-size: 18px;
        }

        /* Footer Links and Contact */
        .footer {
            text-align: center;
            padding: 40px 20px;
            background-color: #ffffff;
        }

        .footer p {
            font-size: 15px;
            color: #333333;
            margin: 8px 0;
            font: 400
        }

        .footer-link {
            color: #58B947;
            text-decoration: none;
            font-weight: 400;
        }

        .whatsapp-number {
            font-weight: 600;
        }

        /* Mobile Adjustments */
        @media only screen and (max-width: 600px) {
            .main {
                border-radius: 0;
            }

            .content {
                padding: 40px 25px;
            }

            .banner-title {
                font-size: 30px;
            }

            .logo-text {
                font-size: 24px;
            }
        }
    </style>
</head>

<body>
    <center class="wrapper">
        <table class="main" width="100%" cellpadding="0" cellspacing="0">
            <!-- Banner Section -->
            <tr>
                <td class="banner" bgcolor="#58B947"
                    style="background-color: #58B947; padding: 40px 0; text-align: center;">
                    <!-- Content Table for Banner -->
                    <table width="100%" cellpadding="0" cellspacing="0" border="0">
                        <tr>
                            <!-- Left Confetti -->
                            <td width="100" align="left" valign="top">
                                <img src="https://res.cloudinary.com/dpcelz9ln/image/upload/v1774049395/image_22_pnvirs.png"
                                    alt="" width="100" style="display: block; border: 0;">
                            </td>
                            <!-- Center Logo -->
                            <td align="center" valign="middle">
                                <img src="https://res.cloudinary.com/dpcelz9ln/image/upload/v1774048840/Frame_2_1_c0idnn.png"
                                    alt="OneGrowth" height="48" style="display: block; margin: 0 auto; border: 0;">
                            </td>
                            <!-- Right Confetti -->
                            <td width="100" align="right" valign="bottom">
                                <img src="https://res.cloudinary.com/dpcelz9ln/image/upload/v1774049431/image_23_emnmz7.png"
                                    alt="" width="100" style="display: block; border: 0;">
                            </td>
                        </tr>
                    </table>

                    <h1 class="banner-title"
                        style="color: #ffffff; font-size: 35px; font-weight: 500; margin: 30px 0 0 0; letter-spacing: -1px; line-height: 1.1;">
                        <%= bannerTitle %>
                    </h1>
                </td>
            </tr>
            <!-- Content Section -->
            <tr>
                <td class="content">
                    <p class="greeting">Hi <%= username %>,</p>

                    <p class="intro-text">Your account has been successfully created.</p>
                    <p class="message">
                        You can now access the platform and begin using tools designed to help you think clearly, stay
                        consistent and make meaningful progress.
                    </p>

                    <div class="button-container">
                        <!-- Using a table here for better button rendering in cross-platform clients -->
                        <table align="center" border="0" cellpadding="0" cellspacing="0">
                            <tr>
                                <td align="center" style="background-color: #58B947; border-radius: 12px;">
                                    <a href="<%= actionUrl %>" class="button">
                                        <%= actionLabel %>
                                    </a>
                                </td>
                            </tr>
                        </table>
                    </div>
                </td>
            </tr>
            <!-- Footer Section -->
            <tr>
                <td class="footer">
                    <p>If you have any issues, kindly contact us at
                        <a href="mailto:support@onegrowth.com" class="footer-link">support@onegrowth.com</a>
                    </p>
                    <p>
                        or send us a WhatsApp message at
                        <span class="whatsapp-number"><a href="https://wa.me/2348050640810" class="footer-link">+234 805
                                064 0810</a></span>
                    </p>
                </td>
            </tr>
        </table>
    </center>
</body>

</html>